    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\n  \"success\": false,\n  \"message\": \"No student emails provided\"\n}",
        "options": {}
      },
      "id": "e7b0a70f-155e-42c2-b52b-4d436a56e7de",
      "name": "Error Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
